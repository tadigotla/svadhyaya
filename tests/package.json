{
  "name": "svadhyaya-tests",
  "private": true,
  "type": "module",
  "description": "Test infrastructure for svadhyaya. The app itself remains build-tooling-free; this directory is the only place Node deps live.",
  "scripts": {
    "test:rules": "vitest run firestore-rules.test.mjs",
    "test:rules:watch": "vitest firestore-rules.test.mjs",
    "emulators": "firebase emulators:start --only firestore,auth --project svadhyaya-rules-test"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "vitest": "^2.1.0"
  }
}
